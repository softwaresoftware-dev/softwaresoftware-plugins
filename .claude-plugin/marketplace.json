      "provides": ["static-site-deploy"],
      "built_in_capabilities": ["static-site-build"],
      "environment": {
        "os": "linux",
        "binary": "cloudflared"
      },
      "grants": {
        "static-site-deploy": ["deploy_static_site"]
      }
    },
    {
