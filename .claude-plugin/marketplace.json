      "version": "1.2.0",
      "author": {
        "name": "Thatcher"
      },
      "homepage": "https://plugins.nov.solutions",
      "license": "MIT",
      "keywords": ["static", "html", "landing-page", "deployment"],
      "category": "development",
      "requires": [],
