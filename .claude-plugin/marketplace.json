        "source": "github",
        "repo": "ThatcherT/nov-hub"
      },
      "description": "Plugin dependency resolver — detects environment, resolves capabilities, auto-selects providers, generates install plans.",
      "version": "1.0.0",
      "author": {
        "name": "Thatcher"
      },
      "homepage": "https://plugins.nov.solutions",
      "license": "MIT",
      "keywords": ["dependencies", "resolver", "capabilities", "framework"],
      "category": "framework",
      "requires": [],
      "optional": [],
      "provides": [],
      "environment": {}
    },
    {
      "name": "zapframe",
      "source": {
        "source": "github",
        "repo": "ThatcherT/zapframe"
      },
      "description": "SaaS project creation agent. Django + Next.js, auth, billing, email, monitoring. One conversation to a deployed app.",
      "version": "1.0.0",
      "author": {
        "name": "Thatcher"
      },
      "homepage": "https://plugins.nov.solutions",
      "license": "MIT",
      "keywords": ["saas", "scaffolding", "django", "nextjs", "deployment"],
      "category": "development",
      "requires": [],
      "optional": [],
      "provides": [],
      "environment": {}
    },
    {
      "name": "liteframe",
